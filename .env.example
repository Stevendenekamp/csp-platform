# ── Database ─────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add a PostgreSQL plugin.
# For local development, SQLite is used by default.
DATABASE_URL=sqlite:///./cutting_platform.db

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python generate_secret_key.py
SECRET_KEY=change-me-to-a-long-random-string

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=False
HOST=0.0.0.0
PORT=8000
APP_BASE_URL=https://your-app.railway.app

# ── Global / Fallback MKG settings (optional) ────────────────────────────────
# Leave empty — each user configures their own MKG credentials via Settings.
MKG_BASE_URL=
MKG_API_KEY=
MKG_USERNAME=
MKG_PASSWORD=
USE_MKG=false
